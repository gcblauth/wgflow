#!/usr/bin/env bash
# wgflow-backup: archive the bind-mounted data directory.
#
# Usage:
#   wgflow-backup [--data-dir DIR] [--dest DIR] [--retain N]
#
# Defaults:
#   --data-dir   ./data            (relative to current dir)
#   --dest       /var/backups/wgflow
#   --retain     14                (days to keep — older files pruned)
#
# What gets backed up:
#   The bind-mounted host directory you've configured in docker-compose.yml
#   as the wgflow data volume. This contains:
#     - wgflow.sqlite (DB: peers, ACLs, DNS history, instance config)
#     - keys/         (server private/public keys)
#     - peers/        (per-peer client config artifacts)
#
# Output:
#   /var/backups/wgflow/wgflow-YYYYMMDD-HHMMSS.tar.gz
#
# Safe to run while the container is up: sqlite WAL handles concurrent reads.
# Tarballs are timestamped, so re-running mid-day adds a new archive without
# overwriting earlier ones.
#
# This script is intended to be invoked by a systemd timer (or cron entry).
# See the install hints at the bottom of this file.

set -euo pipefail

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

data_dir="./data"
dest="/var/backups/wgflow"
retain=14

while [ $# -gt 0 ]; do
    case "$1" in
        --data-dir) data_dir="$2"; shift 2 ;;
        --dest)     dest="$2";     shift 2 ;;
        --retain)   retain="$2";   shift 2 ;;
        -h|--help)
            sed -n '2,/^# This script/p' "$0" | sed 's/^# \?//'
            exit 0
            ;;
        *) echo "unknown arg: $1" >&2; exit 1 ;;
    esac
done

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------

if [ ! -d "$data_dir" ]; then
    echo "error: data dir not found: $data_dir" >&2
    echo "       (point at the host-side bind mount used in docker-compose.yml)" >&2
    exit 1
fi

if [ "$(id -u)" -ne 0 ]; then
    echo "warning: not running as root — may not be able to read all files" >&2
    # Don't exit; some setups have the data dir owned by a non-root user
    # the operator is already running as.
fi

mkdir -p "$dest"

# ---------------------------------------------------------------------------
# Archive
# ---------------------------------------------------------------------------

ts="$(date +%Y%m%d-%H%M%S)"
out="$dest/wgflow-$ts.tar.gz"

# `-C "$data_dir" .` lets the tarball expand into a fresh directory cleanly:
# `tar xzf wgflow-X.tar.gz -C ./restored/` produces ./restored/wgflow.sqlite,
# ./restored/keys/, etc. — without an awkward leading "data/" wrapper.
tar -czf "$out" -C "$data_dir" .

size_kb="$(du -k "$out" | cut -f1)"
echo "[wgflow-backup] wrote $out (${size_kb} KB)"

# ---------------------------------------------------------------------------
# Retention
# ---------------------------------------------------------------------------

# `find -mtime +N` matches files modified more than N days ago.
# We use the file's mtime (which equals the create time, since we just made
# it). This deletes anything older than `retain` days regardless of who
# created it — fine because the directory is single-purpose.
find "$dest" -maxdepth 1 -name 'wgflow-*.tar.gz' -mtime +"$retain" -print -delete \
    | sed 's|^|[wgflow-backup] pruned |'

# ---------------------------------------------------------------------------
# Install hints (systemd timer setup)
# ---------------------------------------------------------------------------
# To run this nightly at 03:00, install these unit files:
#
# /etc/systemd/system/wgflow-backup.service:
#   [Unit]
#   Description=wgflow data backup
#   [Service]
#   Type=oneshot
#   WorkingDirectory=/path/to/your/wgflow/compose/dir
#   ExecStart=/usr/local/bin/wgflow-backup
#
# /etc/systemd/system/wgflow-backup.timer:
#   [Unit]
#   Description=Nightly wgflow backup
#   [Timer]
#   OnCalendar=03:00
#   Persistent=true
#   [Install]
#   WantedBy=timers.target
#
# Then:
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now wgflow-backup.timer

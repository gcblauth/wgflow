#!/usr/bin/env bash
# wgflow-update: rebuild + recreate the wgflow container from a new release.
#
# Usage:
#   wgflow-update <path-to-extracted-wgflow-source>
#
# Example flow:
#   tar -xzf wgflow-v3.6.tar.gz
#   sudo wgflow-update ./wgflow-v3.6
#
# What it does:
#   1. Validates the source has the expected layout (Dockerfile + app/)
#   2. Rsyncs the source into the directory containing your docker-compose.yml
#      (the script's parent of cwd, by default — pass --compose-dir if different)
#   3. Runs `docker compose build` to rebuild the image
#   4. Runs `docker compose up -d` to recreate the container with the new image
#   5. Tails the container's last 30 log lines so you can see startup
#
# This script assumes:
#   - You're using Pattern A (build locally from source tarball).
#   - Your docker-compose.yml uses bind mounts for data, so the rebuild
#     doesn't touch your peer DB / keys / DNS history.
#   - The `docker compose` v2 CLI is available (NOT the legacy `docker-compose`).
#
# What it deliberately does NOT do:
#   - It does not pull from a registry.
#   - It does not back up the data directory before updating.
#     (The Docker image rebuild does not touch bind-mounted volumes, so
#     a separate backup is recommended but not coupled to the update flow.
#     See scripts/wgflow-backup for that.)
#   - It does not auto-extract a .tar.gz — pass an already-extracted dir.
#
# Bare-metal users: this script is Docker-only. For bare-metal updates, the
# v3.5-era flow (rsync app/ into /opt/wgflow/app, restart systemd unit) still
# works manually. See README's "experimental: bare-metal" section.

set -euo pipefail

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------

usage() {
    cat <<EOF
usage: wgflow-update <path-to-extracted-wgflow-source> [--compose-dir DIR]

Updates a Docker-based wgflow deployment by rsync-ing new source files into
the compose directory, rebuilding the image, and recreating the container.

Options:
  --compose-dir DIR   Where docker-compose.yml lives (default: current dir)

Example:
    tar -xzf wgflow-v3.6.tar.gz
    sudo wgflow-update ./wgflow-v3.6
EOF
    exit 1
}

[ $# -lt 1 ] && usage

src="$1"
shift
compose_dir="$(pwd)"

while [ $# -gt 0 ]; do
    case "$1" in
        --compose-dir) compose_dir="$2"; shift 2 ;;
        -h|--help)     usage ;;
        *) echo "unknown arg: $1"; usage ;;
    esac
done

# ---------------------------------------------------------------------------
# Validation
# ---------------------------------------------------------------------------

if [ ! -d "$src" ]; then
    echo "error: source directory not found: $src" >&2
    exit 1
fi

src="$(cd "$src" && pwd)"   # canonicalize

# Sanity-check the source looks like a wgflow release
for required in Dockerfile docker-compose.yml app entrypoint.sh; do
    if [ ! -e "$src/$required" ]; then
        echo "error: $src does not look like a wgflow source dir" >&2
        echo "       (missing: $required)" >&2
        exit 1
    fi
done

if [ ! -f "$compose_dir/docker-compose.yml" ]; then
    echo "error: no docker-compose.yml in $compose_dir" >&2
    echo "       (use --compose-dir to point elsewhere)" >&2
    exit 1
fi

# Need root to be able to rsync into a system path and run docker.
# If the operator already has Docker permissions without sudo, this still
# works — `sudo -n true` returns 0 in that case via cached creds.
if [ "$(id -u)" -ne 0 ]; then
    echo "error: must run as root (or with sudo)" >&2
    exit 1
fi

if ! command -v docker &>/dev/null; then
    echo "error: docker not found on PATH" >&2
    exit 1
fi

if ! docker compose version &>/dev/null; then
    echo "error: 'docker compose' v2 not available" >&2
    echo "       (this script does not support legacy docker-compose v1)" >&2
    exit 1
fi

# ---------------------------------------------------------------------------
# Confirmation
# ---------------------------------------------------------------------------

echo "[wgflow-update] source:        $src"
echo "[wgflow-update] compose dir:   $compose_dir"
echo "[wgflow-update] this will:"
echo "                  1. rsync source files into $compose_dir"
echo "                  2. docker compose build"
echo "                  3. docker compose up -d (recreates the container)"
echo "                  4. show last 30 log lines"
echo ""
read -r -p "[wgflow-update] proceed? [y/N] " confirm
case "$confirm" in
    y|Y|yes|YES) ;;
    *) echo "aborted."; exit 0 ;;
esac

# ---------------------------------------------------------------------------
# Sync
# ---------------------------------------------------------------------------

echo "[wgflow-update] syncing source files…"

# We rsync only the things that change between releases:
#   - app/ (the Python application)
#   - Dockerfile (the build recipe)
#   - entrypoint.sh (container startup)
#   - dnsmasq.conf.template
#   - requirements / setup files if present
#
# We DO NOT touch:
#   - docker-compose.yml (operator may have customized envvars, ports, mounts)
#   - .env (secrets / passwords)
#   - data/ (peer DB, keys, DNS history — bind-mounted, sacred)
#   - .git, .venv, node_modules (development artifacts)

rsync -a --delete "$src/app/" "$compose_dir/app/"

for f in Dockerfile entrypoint.sh dnsmasq.conf.template; do
    if [ -f "$src/$f" ]; then
        cp -p "$src/$f" "$compose_dir/$f"
    fi
done

# Copy the scripts directory so the operator gets future versions of
# wgflow-update + wgflow-backup automatically when they update.
if [ -d "$src/scripts" ]; then
    mkdir -p "$compose_dir/scripts"
    cp -p "$src/scripts/"* "$compose_dir/scripts/" 2>/dev/null || true
fi

# ---------------------------------------------------------------------------
# Build + restart
# ---------------------------------------------------------------------------

echo "[wgflow-update] building image…"
( cd "$compose_dir" && docker compose build )

echo "[wgflow-update] recreating container…"
( cd "$compose_dir" && docker compose up -d )

# ---------------------------------------------------------------------------
# Show startup logs
# ---------------------------------------------------------------------------

# Wait briefly so the container has a chance to emit its startup banner
sleep 3

echo ""
echo "[wgflow-update] last 30 log lines:"
echo "----------------------------------------------------------------"
( cd "$compose_dir" && docker compose logs --tail 30 )
echo "----------------------------------------------------------------"
echo ""
echo "[wgflow-update] done."
echo "                if anything looks off, run:"
echo "                  cd $compose_dir && docker compose logs -f"
